{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "eud-agent",
  "version": "0.1.0",
  "identifier": "dev.tree-some.eud-agent",
  "build": {
    "frontendDist": "../panel/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "eud-agent",
        "width": 1280,
        "height": 832,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "resources": {
      "../bridge/ZZZ_10_agent_bridge.lua": "bridge/ZZZ_10_agent_bridge.lua"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      },
      "nsis": {
        "languages": ["Korean", "English"],
        "displayLanguageSelector": true,
        "installMode": "currentUser",
        "installerIcon": "icons/icon.ico",
        "headerImage": "installer/header.bmp",
        "sidebarImage": "installer/sidebar.bmp",
        "installerHooks": "installer/hooks.nsh"
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/raravel/eud-agent/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDlERTA4QTdENjRGRDAzMTMKUldRVEEvMWtmWXJnblJRbVJlcXN1UCs5VGlCaHgvVWRVczNOd1pGam80MjBIQzJmQUNmSTdLV00K"
    }
  }
}
