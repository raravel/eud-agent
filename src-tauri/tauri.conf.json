{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "eud-agent",
  "version": "0.1.0",
  "identifier": "dev.tree-some.eud-agent",
  "build": {
    "frontendDist": "../panel/dist"
  },
  "app": {
    "windows": [
      {
        "title": "eud-agent",
        "width": 1280,
        "height": 832,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    }
  }
}
