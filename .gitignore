# Python virtualenv
.venv/

# Python bytecode / caches
__pycache__/
*.pyc
*.pyo

# Tooling caches
.ruff_cache/
.pytest_cache/

# Node (optional epscript-lsp, panel tooling)
node_modules/
panel/node_modules/

# Panel build output (Vite); never committed, release-packaged later
panel/dist/

# Distribution / release staging output
release/

# Playwright MCP debugging artifacts (console logs, page snapshots)
.playwright-mcp/

# Claude Code agent worktrees
.claude/worktrees/

# Rust / Cargo workspace build output
/target/

# Shared cargo target cache for hv:task worktree workers (warmed dep artifacts;
# avoids per-worktree cold compiles of ort/fastembed/tauri). Not committed.
/.cargo-shared-target/

# fastembed model cache (the bge-m3 ONNX ~560MB) — written by rag tests/runtime
# when no explicit cache dir is set (default is CWD-relative). Never committed.
.fastembed_cache/

# Tauri build-time generated artifacts (regenerated by tauri-build each build)
src-tauri/gen/

# ICU header-staging output from the isom-sys MSBuild (IcuLib copies its public
# headers here, OUTSIDE native/isom/; regenerated every build, never committed)
native/include/
